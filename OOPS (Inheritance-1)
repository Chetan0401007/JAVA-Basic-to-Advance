package circlee;
class Circle{
double r;
public double area(){
    return Math.PI*r*r;
}
public double Circumference(){
    return 2*Math.PI*r;
}
public Circle(double r){
    this.r=r;
}
}
class Cylinder extends Circle{
   double h;
   public double vol(){
       return area()*h;
   }
   public Cylinder(double r,double h){
       super(r);
       this.h=h;
   }
}
